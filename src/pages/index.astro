---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Moxie's Run For Canine Cancer — 5K Run/Walk">
  <Header />

  <!-- Hero Section -->
  <section class="relative bg-brand min-h-[80vh] flex items-center justify-center text-center text-white overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-brand/80 to-brand/60"></div>
    <div class="absolute inset-0 bg-[url('/images/hero-home-1.jpg')] bg-cover bg-center opacity-30"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 py-24">
      <h1 class="font-heading text-5xl md:text-7xl font-extrabold mb-6 leading-tight">
        Moxie's Run<br />
        <span class="text-accent">For Canine Cancer</span>
      </h1>
      <p class="text-xl md:text-2xl text-gray-200 mb-10 max-w-2xl mx-auto leading-relaxed">
        A 5K run/walk bringing together dog lovers to raise awareness and funds for canine cancer research.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/registration"
          class="bg-accent hover:bg-accent-light text-white font-heading font-bold text-lg uppercase tracking-wide px-10 py-4 rounded-full transition-colors shadow-lg"
        >
          Register Now
        </a>
        <a
          href="/about"
          class="border-2 border-white/50 hover:border-white text-white font-heading font-bold text-lg uppercase tracking-wide px-10 py-4 rounded-full transition-colors"
        >
          Learn More
        </a>
      </div>
    </div>
  </section>

  <!-- Event Details Bar -->
  <section class="bg-accent text-white py-6">
    <div class="max-w-6xl mx-auto px-4 grid grid-cols-1 md:grid-cols-4 gap-6 text-center">
      <div>
        <p class="font-heading font-bold text-lg">Date</p>
        <p class="text-sm">Sunday, April 27th, 2025</p>
      </div>
      <div>
        <p class="font-heading font-bold text-lg">Location</p>
        <p class="text-sm">Muddy York Brewery, Stouffville, ON</p>
      </div>
      <div>
        <p class="font-heading font-bold text-lg">Race Start</p>
        <p class="text-sm">9:00 AM Sharp</p>
      </div>
      <div>
        <p class="font-heading font-bold text-lg">Spots</p>
        <p class="text-sm">Limited to 200 Dog+Human Pairs</p>
      </div>
    </div>
  </section>

  <!-- Mission Section -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="font-heading text-4xl md:text-5xl font-bold text-brand mb-6">The Mission</h2>
          <p class="text-lg text-gray-600 leading-relaxed mb-6">
            Moxie's Run raises awareness and funds for canine cancer prevention, diagnosis, and treatment. Every donation directly supports research and development for fighting canine cancer.
          </p>
          <p class="text-lg text-gray-600 leading-relaxed mb-8">
            Together, we can make a difference in the lives of dogs and their families. Our combined proceeds benefit both a local charity and the National Canine Cancer Foundation.
          </p>
          <a
            href="/about"
            class="inline-block bg-brand hover:bg-brand-light text-white font-heading font-bold text-sm uppercase tracking-wide px-8 py-3 rounded-full transition-colors"
          >
            About the Cause
          </a>
        </div>
        <div class="rounded-2xl overflow-hidden aspect-square">
          <img src="/images/content-home.jpg" alt="Dogs at Moxie's Run event" class="w-full h-full object-cover" />
        </div>
      </div>
    </div>
  </section>

  <!-- What We Fund -->
  <section class="py-20 bg-cream">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <h2 class="font-heading text-4xl md:text-5xl font-bold text-brand mb-4">Where Your Support Goes</h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto mb-16">
        Every dollar raised through Moxie's Run goes directly toward making a difference.
      </p>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white rounded-2xl p-8 shadow-sm">
          <div class="w-16 h-16 bg-accent/10 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-brand mb-3">Fund Research</h3>
          <p class="text-gray-600 leading-relaxed">
            Support vital veterinary oncology research and development for improved canine cancer treatments and cures.
          </p>
        </div>
        <div class="bg-white rounded-2xl p-8 shadow-sm">
          <div class="w-16 h-16 bg-accent/10 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-brand mb-3">Family Assistance</h3>
          <p class="text-gray-600 leading-relaxed">
            Establish support funds offering financial assistance to families facing the burden of canine cancer treatment costs.
          </p>
        </div>
        <div class="bg-white rounded-2xl p-8 shadow-sm">
          <div class="w-16 h-16 bg-accent/10 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-brand mb-3">Advance Treatment</h3>
          <p class="text-gray-600 leading-relaxed">
            Improve detection, treatment options, and quality of life for dogs affected by cancer through better veterinary care.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Registration CTA -->
  <section class="py-20 bg-brand text-white text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl font-bold mb-6">Join the Run</h2>
      <p class="text-xl text-gray-300 mb-10 leading-relaxed">
        Whether you run with your dog or on your own, every registration helps fight canine cancer. Limited spots available for dog+human pairs.
      </p>
      <a
        href="/registration"
        class="inline-block bg-accent hover:bg-accent-light text-white font-heading font-bold text-lg uppercase tracking-wide px-12 py-4 rounded-full transition-colors shadow-lg"
      >
        Register Now
      </a>
    </div>
  </section>

  <Footer />
</Layout>
