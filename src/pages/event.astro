---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Event & Race Day — Moxie's Run For Canine Cancer">
  <Header />

  <!-- Hero -->
  <section class="bg-brand text-white py-20">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="font-heading text-5xl md:text-6xl font-extrabold mb-6">Event & Race Day</h1>
      <p class="text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed">
        Join us for our SECOND EVER Moxie's Run For Canine Cancer!
      </p>
    </div>
  </section>

  <!-- Event Details -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-16">
        <!-- Details -->
        <div>
          <h2 class="font-heading text-4xl font-bold text-brand mb-8">The 5K Run</h2>
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-accent/10 rounded-full flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="font-heading font-bold text-brand">Date</h3>
                <p class="text-gray-600">Sunday, April 27th, 2025</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-accent/10 rounded-full flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-heading font-bold text-brand">Location</h3>
                <p class="text-gray-600">50 Innovator Ave Unit #1</p>
                <p class="text-gray-600">Whitchurch-Stouffville, ON L4A 0Y2</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-accent/10 rounded-full flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-heading font-bold text-brand">Race Start</h3>
                <p class="text-gray-600">9:00 AM Sharp</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-accent/10 rounded-full flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-heading font-bold text-brand">Spots</h3>
                <p class="text-gray-600">Limited to 200 dog+human pairs</p>
                <p class="text-gray-500 text-sm">Unlimited human-only spots</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-accent/10 rounded-full flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              </div>
              <div>
                <h3 class="font-heading font-bold text-brand">Time Limit</h3>
                <p class="text-gray-600">1 hour, 30 minutes to complete</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Race Kit -->
        <div>
          <h2 class="font-heading text-4xl font-bold text-brand mb-8">Race Kit</h2>
          <div class="bg-cream rounded-2xl p-8">
            <p class="text-lg text-gray-600 mb-6">Every participant receives:</p>
            <ul class="space-y-4">
              <li class="flex items-center gap-3">
                <svg class="w-5 h-5 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-700">Bib Number</span>
              </li>
              <li class="flex items-center gap-3">
                <svg class="w-5 h-5 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-700">Finisher Medal</span>
              </li>
            </ul>
          </div>

          <div class="mt-8 rounded-2xl overflow-hidden">
            <img src="/images/course-map.jpg" alt="5K Course Map" class="w-full h-auto" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Schedule -->
  <section class="py-20 bg-cream">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-heading text-4xl font-bold text-brand text-center mb-16">Race Day Schedule</h2>
      <div class="space-y-0">
        <div class="flex gap-6 items-start">
          <div class="w-28 shrink-0 text-right">
            <span class="font-heading font-bold text-accent text-lg">7:30 AM</span>
          </div>
          <div class="w-4 flex flex-col items-center">
            <div class="w-4 h-4 bg-accent rounded-full"></div>
            <div class="w-0.5 h-16 bg-accent/30"></div>
          </div>
          <div class="pb-8">
            <h3 class="font-heading font-bold text-brand text-lg">Baggage Check & Vendors Open</h3>
            <p class="text-gray-600">Drop off your gear and browse vendor booths</p>
          </div>
        </div>
        <div class="flex gap-6 items-start">
          <div class="w-28 shrink-0 text-right">
            <span class="font-heading font-bold text-accent text-lg">8:30 AM</span>
          </div>
          <div class="w-4 flex flex-col items-center">
            <div class="w-4 h-4 bg-accent rounded-full"></div>
            <div class="w-0.5 h-16 bg-accent/30"></div>
          </div>
          <div class="pb-8">
            <h3 class="font-heading font-bold text-brand text-lg">Warm-Up</h3>
            <p class="text-gray-600">Get loose and ready with group warm-up activities</p>
          </div>
        </div>
        <div class="flex gap-6 items-start">
          <div class="w-28 shrink-0 text-right">
            <span class="font-heading font-bold text-accent text-lg">9:00 AM</span>
          </div>
          <div class="w-4 flex flex-col items-center">
            <div class="w-4 h-4 bg-accent rounded-full"></div>
            <div class="w-0.5 h-16 bg-accent/30"></div>
          </div>
          <div class="pb-8">
            <h3 class="font-heading font-bold text-brand text-lg">5K Run/Walk Begins</h3>
            <p class="text-gray-600">The race starts! Run or walk — your pace, your way</p>
          </div>
        </div>
        <div class="flex gap-6 items-start">
          <div class="w-28 shrink-0 text-right">
            <span class="font-heading font-bold text-accent text-lg">10:30 AM</span>
          </div>
          <div class="w-4 flex flex-col items-center">
            <div class="w-4 h-4 bg-accent rounded-full"></div>
            <div class="w-0.5 h-16 bg-accent/30"></div>
          </div>
          <div class="pb-8">
            <h3 class="font-heading font-bold text-brand text-lg">Awards & Closing Ceremony</h3>
            <p class="text-gray-600">Celebrate the finishers and top performers</p>
          </div>
        </div>
        <div class="flex gap-6 items-start">
          <div class="w-28 shrink-0 text-right">
            <span class="font-heading font-bold text-accent text-lg">11:00 AM</span>
          </div>
          <div class="w-4 flex flex-col items-center">
            <div class="w-4 h-4 bg-accent rounded-full"></div>
          </div>
          <div>
            <h3 class="font-heading font-bold text-brand text-lg">Full Park Access</h3>
            <p class="text-gray-600">Enjoy the grounds, vendors, and community after the race</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-brand text-white text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="font-heading text-4xl font-bold mb-6">Ready to Run?</h2>
      <p class="text-xl text-gray-300 mb-10">Secure your spot before the 200 dog+human pairs sell out.</p>
      <a
        href="/registration"
        class="inline-block bg-accent hover:bg-accent-light text-white font-heading font-bold text-lg uppercase tracking-wide px-12 py-4 rounded-full transition-colors shadow-lg"
      >
        Register Now
      </a>
    </div>
  </section>

  <Footer />
</Layout>
