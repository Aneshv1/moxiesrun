---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Fundraising & Donations — Moxie's Run For Canine Cancer">
  <Header />

  <!-- Hero -->
  <section class="bg-brand text-white py-20">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="font-heading text-5xl md:text-6xl font-extrabold mb-6">Fundraising & Donations</h1>
      <p class="text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed">
        Every donation made to Moxie's Run for canine cancer will directly support research and development for fighting canine cancer.
      </p>
    </div>
  </section>

  <!-- Donation Options -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="font-heading text-4xl font-bold text-brand text-center mb-4">Make a Donation</h2>
      <p class="text-lg text-gray-600 text-center max-w-2xl mx-auto mb-16">
        Combined proceeds benefit both a local charity and the National Canine Cancer Foundation.
      </p>

      <div class="grid md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        <!-- $25 Donation -->
        <div class="bg-cream rounded-2xl p-8 text-center shadow-sm hover:shadow-md transition-shadow">
          <div class="w-16 h-16 bg-accent/10 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
          </div>
          <h3 class="font-heading text-2xl font-bold text-brand mb-2">$25</h3>
          <p class="text-gray-600 mb-6">Donation</p>
          <a
            href="#"
            class="inline-block w-full bg-accent hover:bg-accent-light text-white font-heading font-bold text-sm uppercase tracking-wide py-3 rounded-full transition-colors"
          >
            Donate $25
          </a>
        </div>

        <!-- $100 Donation -->
        <div class="bg-cream rounded-2xl p-8 text-center shadow-sm hover:shadow-md transition-shadow ring-2 ring-accent">
          <div class="w-16 h-16 bg-accent/10 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
          </div>
          <h3 class="font-heading text-2xl font-bold text-brand mb-2">$100</h3>
          <p class="text-gray-600 mb-6">Donation</p>
          <a
            href="#"
            class="inline-block w-full bg-accent hover:bg-accent-light text-white font-heading font-bold text-sm uppercase tracking-wide py-3 rounded-full transition-colors"
          >
            Donate $100
          </a>
        </div>

        <!-- Merch -->
        <div class="bg-cream rounded-2xl overflow-hidden text-center shadow-sm hover:shadow-md transition-shadow">
          <img src="/images/fundraising-hoodie-1.png" alt="Moxie's Run Athletic Pullover Hoodie" class="w-full h-48 object-contain bg-white p-4" />
          <div class="p-8">
            <h3 class="font-heading text-lg font-bold text-brand mb-1">Athletic Pullover</h3>
            <p class="text-sm text-gray-500 mb-1">Unisex Hoodie</p>
            <p class="font-heading text-2xl font-bold text-brand mb-6">$74.14</p>
            <a
              href="#"
              class="inline-block w-full bg-accent hover:bg-accent-light text-white font-heading font-bold text-sm uppercase tracking-wide py-3 rounded-full transition-colors"
            >
              Shop Now
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Impact -->
  <section class="py-20 bg-cream">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="font-heading text-4xl font-bold text-brand mb-6">Your Contribution Matters</h2>
      <p class="text-lg text-gray-600 leading-relaxed mb-8">
        The organization allocates donations toward expanding the event to collect additional funds, with combined proceeds benefiting both a local charity and the National Canine Cancer Foundation. Your contribution will make a difference in advancing this important cause.
      </p>
      <a
        href="/registration"
        class="inline-block bg-brand hover:bg-brand-light text-white font-heading font-bold text-sm uppercase tracking-wide px-8 py-3 rounded-full transition-colors"
      >
        Register for the Run
      </a>
    </div>
  </section>

  <Footer />
</Layout>
