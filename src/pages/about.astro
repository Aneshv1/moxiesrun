---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="About the Cause — Moxie's Run For Canine Cancer">
  <Header />

  <!-- Hero -->
  <section class="bg-brand text-white py-20">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="font-heading text-5xl md:text-6xl font-extrabold mb-6">About the Cause</h1>
      <p class="text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed">
        Honoring Moxie. Fighting canine cancer. Supporting families.
      </p>
    </div>
  </section>

  <!-- Moxie's Story -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div class="rounded-2xl overflow-hidden aspect-square">
          <img src="/images/about-hero.jpg" alt="Moxie the Beagle" class="w-full h-full object-cover" />
        </div>
        <div>
          <h2 class="font-heading text-4xl font-bold text-brand mb-6">Moxie's Story</h2>
          <p class="text-lg text-gray-600 leading-relaxed mb-6">
            Moxie's Run honors a beloved Beagle named Moxie who bravely battled brain and thyroid cancer. Her fight inspired a movement to help other dogs and families facing the same devastating diagnosis.
          </p>
          <p class="text-lg text-gray-600 leading-relaxed">
            This initiative brings together a compassionate community of pet lovers, advocates, and supporters through an annual race event — uniting us in the fight against canine cancer.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Objectives -->
  <section class="py-20 bg-cream">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="font-heading text-4xl font-bold text-brand text-center mb-16">Our Key Objectives</h2>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-white rounded-2xl p-8 shadow-sm">
          <div class="w-12 h-12 bg-accent/10 rounded-full flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-brand mb-3">Fund Research</h3>
          <p class="text-gray-600 leading-relaxed">
            Support vital veterinary oncology research and development for improved canine cancer treatments and potential cures.
          </p>
        </div>
        <div class="bg-white rounded-2xl p-8 shadow-sm">
          <div class="w-12 h-12 bg-accent/10 rounded-full flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-brand mb-3">Provide Family Assistance</h3>
          <p class="text-gray-600 leading-relaxed">
            Establish support funds offering financial assistance to families facing canine cancer challenges, helping them avoid difficult healthcare decisions based on cost constraints.
          </p>
        </div>
        <div class="bg-white rounded-2xl p-8 shadow-sm">
          <div class="w-12 h-12 bg-accent/10 rounded-full flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-brand mb-3">Reduce Financial Burden</h3>
          <p class="text-gray-600 leading-relaxed">
            Help families navigate the costly journey of canine cancer treatment so no one has to choose between their pet's health and their finances.
          </p>
        </div>
        <div class="bg-white rounded-2xl p-8 shadow-sm">
          <div class="w-12 h-12 bg-accent/10 rounded-full flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-brand mb-3">Advance Treatment</h3>
          <p class="text-gray-600 leading-relaxed">
            Improve detection, treatment options, and quality of life for dogs affected by cancer through better veterinary oncology practices.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Where Donations Go -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="font-heading text-4xl font-bold text-brand mb-6">Where Donations Go</h2>
      <p class="text-lg text-gray-600 leading-relaxed mb-12">
        Every donation made to Moxie's Run for canine cancer directly supports:
      </p>
      <div class="space-y-6 text-left max-w-2xl mx-auto">
        <div class="flex items-start gap-4">
          <div class="w-8 h-8 bg-accent rounded-full flex items-center justify-center shrink-0 mt-0.5">
            <span class="text-white font-bold text-sm">1</span>
          </div>
          <p class="text-lg text-gray-600">Research and development for canine cancer treatment</p>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-8 h-8 bg-accent rounded-full flex items-center justify-center shrink-0 mt-0.5">
            <span class="text-white font-bold text-sm">2</span>
          </div>
          <p class="text-lg text-gray-600">Support funds for families (applicants must apply for funding)</p>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-8 h-8 bg-accent rounded-full flex items-center justify-center shrink-0 mt-0.5">
            <span class="text-white font-bold text-sm">3</span>
          </div>
          <p class="text-lg text-gray-600">Veterinary oncology advancement and improved treatment access</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-brand text-white text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="font-heading text-4xl font-bold mb-6">Be Part of the Fight</h2>
      <p class="text-xl text-gray-300 mb-10 leading-relaxed">
        Your contribution will make a difference in advancing this important cause.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/registration"
          class="bg-accent hover:bg-accent-light text-white font-heading font-bold text-lg uppercase tracking-wide px-10 py-4 rounded-full transition-colors shadow-lg"
        >
          Register Now
        </a>
        <a
          href="/fundraising"
          class="border-2 border-white/50 hover:border-white text-white font-heading font-bold text-lg uppercase tracking-wide px-10 py-4 rounded-full transition-colors"
        >
          Donate
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
