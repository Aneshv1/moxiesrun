---
const currentYear = new Date().getFullYear();
---

<footer class="bg-brand text-white">
  <div class="max-w-6xl mx-auto px-4 py-16">
    <div class="grid md:grid-cols-3 gap-12">
      <!-- Brand -->
      <div>
        <img src="/images/logo-secondary.png" alt="Moxie's Run" class="h-16 w-auto mb-4" />
        <p class="text-gray-300 leading-relaxed">
          Raising awareness and funds for canine cancer research, prevention, and family support.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="font-heading font-bold uppercase tracking-wide text-sm mb-4 text-accent">Quick Links</h4>
        <ul class="space-y-2">
          <li><a href="/about" class="text-gray-300 hover:text-white transition-colors">About the Cause</a></li>
          <li><a href="/event" class="text-gray-300 hover:text-white transition-colors">Event & Race Day</a></li>
          <li><a href="/sponsors" class="text-gray-300 hover:text-white transition-colors">Sponsors</a></li>
          <li><a href="/fundraising" class="text-gray-300 hover:text-white transition-colors">Fundraising & Donations</a></li>
          <li><a href="/registration" class="text-gray-300 hover:text-white transition-colors">Register Now</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-heading font-bold uppercase tracking-wide text-sm mb-4 text-accent">Contact</h4>
        <ul class="space-y-2 text-gray-300">
          <li>
            <a href="tel:6473767016" class="hover:text-white transition-colors">647-376-7016</a>
          </li>
          <li>
            <a href="mailto:info@k9academy.ca" class="hover:text-white transition-colors">info@k9academy.ca</a>
          </li>
          <li>Toronto, Ontario</li>
        </ul>
        <div class="flex gap-4 mt-4">
          <a
            href="https://www.instagram.com/k9academyto"
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-300 hover:text-accent transition-colors"
            aria-label="Instagram"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a
            href="https://www.facebook.com/k9expeditions"
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-300 hover:text-accent transition-colors"
            aria-label="Facebook"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385h-3.047v-3.47h3.047v-2.642c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953h-1.514c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385c5.738-.9 10.126-5.864 10.126-11.854z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <div class="border-t border-white/20 mt-12 pt-8 text-center text-gray-400 text-sm">
      <p>&copy; {currentYear} Moxie's Run For Canine Cancer. All rights reserved.</p>
    </div>
  </div>
</footer>
