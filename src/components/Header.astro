---
const navLinks = [
  { label: "About", href: "/about" },
  { label: "Event & Race Day", href: "/event" },
  { label: "Sponsors", href: "/sponsors" },
  { label: "Fundraising & Donations", href: "/fundraising" },
  { label: "Registration", href: "/registration" },
];
---

<!-- Navigation -->
<header class="bg-white border-b border-gray-100 sticky top-0 z-50">
  <nav class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2">
      <img src="/images/logo-main.png" alt="Moxie's Run" class="h-12 w-auto" />
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden lg:flex items-center gap-6">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="font-heading text-sm font-semibold text-gray-700 hover:text-brand transition-colors uppercase tracking-wide"
          >
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="/registration"
          class="bg-brand hover:bg-brand-light text-white font-heading font-bold text-sm uppercase tracking-wide px-6 py-3 rounded-md transition-colors"
        >
          Register Now
        </a>
      </li>
    </ul>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="lg:hidden flex flex-col gap-1.5 p-2"
      aria-label="Toggle menu"
    >
      <span class="block w-6 h-0.5 bg-gray-800 transition-transform" id="bar1"></span>
      <span class="block w-6 h-0.5 bg-gray-800 transition-opacity" id="bar2"></span>
      <span class="block w-6 h-0.5 bg-gray-800 transition-transform" id="bar3"></span>
    </button>
  </nav>

  <!-- Mobile Nav -->
  <div id="mobile-menu" class="hidden lg:hidden bg-white border-t">
    <ul class="flex flex-col px-4 py-4 gap-3">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="block font-heading text-sm font-semibold text-gray-700 hover:text-brand uppercase tracking-wide py-2"
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="pt-2">
        <a
          href="/registration"
          class="block text-center bg-brand hover:bg-brand-light text-white font-heading font-bold text-sm uppercase tracking-wide px-6 py-3 rounded-md transition-colors"
        >
          Register Now
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
</script>
